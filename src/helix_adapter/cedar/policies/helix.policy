// Helix Agent Policy — Dual-Gate Containment
// RFC 0003 reference implementation
//
// Based on Cedar best practices:
// - Head constraints define the policy scope
// - Schema drives entity and action structure
// - Structured context, not string matching in when clauses

// --- Response Gate (Duck Gate) ---

permit(
    principal is Helix::Agent,
    action == Helix_Governance::Action::"respond",
    resource is Helix::Environment
)
when {
    context.drift_score.lessThan(decimal("0.17")) &&
    context.marker_count >= 1 &&
    context.has_valid_receipt
};

// --- Action Gate (Cedar Gate) ---

// Block path traversal attempts on any action that accepts a path
forbid(
    principal is Helix::Agent,
    action,
    resource
)
when {
    context has path &&
    context.path like "*../*"
};

// Block bash outside sandbox; block wallet_transfer entirely
forbid(
    principal is Helix::Agent,
    action == Helix::Action::"bash",
    resource
)
unless {
    context has path &&
    context.path like "/home/agent/sandbox/*"
};

forbid(
    principal is Helix::Agent,
    action == Helix::Action::"wallet_transfer",
    resource
);

// Allow bash in sandboxed workspaces
permit(
    principal is Helix::Agent,
    action == Helix::Action::"bash",
    resource
)
when {
    context has path &&
    context.path like "/home/agent/sandbox/*"
};

// Allow file operations (patch, write, edit) outside protected paths
permit(
    principal is Helix::Agent,
    action == Helix::Action::"apply_patch",
    resource
)
when {
    context has path &&
    !(context.path like "/etc/*") &&
    !(context.path like "*.env")
};

permit(
    principal is Helix::Agent,
    action == Helix::Action::"write_file",
    resource
)
when {
    context has path &&
    !(context.path like "/etc/*") &&
    !(context.path like "*.env")
};

permit(
    principal is Helix::Agent,
    action == Helix::Action::"edit_file",
    resource
)
when {
    context has path &&
    !(context.path like "/etc/*") &&
    !(context.path like "*.env")
};

// Allow API calls to approved endpoints
permit(
    principal is Helix::Agent,
    action == Helix::Action::"api_call",
    resource
)
when {
    context has endpoint &&
    (
        context.endpoint like "https://api.github.com/*" ||
        context.endpoint like "https://pypi.org/*" ||
        context.endpoint like "https://*.openai.azure.com/*"
    )
};
