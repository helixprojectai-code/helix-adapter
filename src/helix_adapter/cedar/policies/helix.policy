// =============================================================================
// Helix Dual-Gate Policy (RFC 0003)
// Combines Duck Gate (response) and Cedar Gate (action) rules
// =============================================================================

// -----------------------------------------------------------------------------
// RESPONSE GATE (Duck Gate integration)
// Only allow responses that meet constitutional standards
// -----------------------------------------------------------------------------
permit (
    principal,
    action == Action::"respond",
    resource
)
when {
    context.has_valid_receipt == true &&
    context.marker_count >= 1 &&
    context.drift_score < decimal("0.17")
};

// -----------------------------------------------------------------------------
// ACTION GATE - Default deny for high-risk operations
// -----------------------------------------------------------------------------
forbid (
    principal,
    action,
    resource
)
when {
    action in [
        Action::"bash:rm -rf",
        Action::"bash:shutdown",
        Action::"bash:reboot",
        Action::"aws:DeleteBucket",
        Action::"aws:TerminateInstances",
        Action::"aws:DeleteUser",
        Action::"wallet:transfer"
    ]
};

// -----------------------------------------------------------------------------
// ACTION GATE - Allow common safe operations with conditions
// -----------------------------------------------------------------------------
permit (
    principal,
    action == Action::"bash",
    resource
)
when {
    context.command like "ls*" ||
    context.command like "cat*" ||
    context.command like "pwd" ||
    context.command like "echo*"
};

permit (
    principal,
    action == Action::"write_file",
    resource
)
when {
    resource.path like "/home/agent/sandbox/*" ||
    resource.path like "/tmp/*"
};

// -----------------------------------------------------------------------------
// ACTION GATE - Allow read-only file operations broadly
// -----------------------------------------------------------------------------
permit (
    principal,
    action == Action::"read_file",
    resource
)
when {
    true
};
